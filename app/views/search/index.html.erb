<div class="search-card">
  <h2 class="section-title">Search Products</h2>

  <%= form_with url: search_path, method: :get, local: true do %>
    <div class="search-box">
      <%= text_field_tag :q, params[:q], placeholder: "Search for a product by name" %>
      <%= submit_tag "Search" %>
    </div>
  <% end %>
</div>

<% if @query.present? %>
  <section>
    <h2 class="section-title">Search Results for "<%= @query %>"</h2>

    <% if @items.any? %>
      <div class="product-grid">
        <% @items.each do |item| %>
          <div class="product-card">
            <h3><%= item.name %></h3>
            <p><%= item.description %></p>
            <p class="price">$<%= item.price %></p>
            <%= link_to "View Product", item_path(item) %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="card">
        <p class="info-text">No products matched your search.</p>
      </div>
    <% end %>
  </section>
<% end %>