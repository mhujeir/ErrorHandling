<section>
  <h2 class="section-title">All Products</h2>

  <div class="product-grid">
    <% @items.each do |item| %>
      <div class="product-card">
        <h3><%= item.name %></h3>
        <p><%= item.description %></p>
        <p class="price">$<%= item.price %></p>
        <%= link_to "View Product", item_path(item) %>
      </div>
    <% end %>
  </div>
</section>